				},
				{
					"name": "Get Job by Job Number",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/jobs/{{jobNumber}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "jobs", "{{jobNumber}}"]
