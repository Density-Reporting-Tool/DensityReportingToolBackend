					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/proctors/job/{{jobNumber}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "proctors", "job", "{{jobNumber}}"]
						}
					}
