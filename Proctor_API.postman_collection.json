				},
				{
					"name": "Get Proctors (Lab Admin - Paginated)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/proctors/lab-admin?page=1&limit=50&jobNumber={{jobNumber}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "proctors", "lab-admin"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "50"
								},
								{
									"key": "jobNumber",
									"value": "{{jobNumber}}"
								}
							]
						}
					}
				}
			]
		},
