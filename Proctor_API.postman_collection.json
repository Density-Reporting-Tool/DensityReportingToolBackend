{
	"info": {
		"name": "Proctor API",
		"description": "Complete API collection for Proctor endpoints",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "General Endpoints",
			"item": [
				{
					"name": "Get All Proctors",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/proctors",
							"host": ["{{baseUrl}}"],
							"path": ["api", "proctors"]
						}
					}
				},
				{
					"name": "Get Proctor by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/proctors/{{proctorId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "proctors", "{{proctorId}}"]
						}
					}
				},
				{
					"name": "Create Proctor (Simple)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"jobNumber\": \"{{jobNumber}}\",\n  \"proctorId\": \"P-002\",\n  \"proctorTestNumber\": \"PT-2024-002\",\n  \"materialType\": \"Clay Soil\",\n  \"labLocation\": \"Main Lab\",\n  \"proctorType\": \"MPDD\",\n  \"maxDensity\": 2056.0,\n  \"correctedDensity\": 2018.0,\n  \"optimumMoisture\": 14.2,\n  \"specificGravity\": 2.68,\n  \"oversizePercentage\": 3.5,\n  \"dateSampled\": \"2024-01-20T00:00:00Z\",\n  \"dateTested\": \"2024-01-25T00:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/proctors",
							"host": ["{{baseUrl}}"],
							"path": ["api", "proctors"]
						}
					}
				},
				{
					"name": "Update Proctor",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": {{proctorId}},\n  \"proctorId\": \"P-002\",\n  \"materialType\": \"Updated Clay Soil\",\n  \"labLocation\": \"Main Lab\",\n  \"proctorType\": \"MPDD\",\n  \"maxDensity\": 2064.0,\n  \"correctedDensity\": 2032.0,\n  \"optimumMoisture\": 14.5,\n  \"specificGravity\": 2.70,\n  \"oversizePercentage\": 3.0,\n  \"dateSampled\": \"2024-01-20T00:00:00Z\",\n  \"dateTested\": \"2024-01-26T00:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/proctors/{{proctorId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "proctors", "{{proctorId}}"]
						}
					}
				},
				{
					"name": "Search Proctors by Job Number",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/proctors/search?jobNumber={{jobNumber}}&limit=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "proctors", "search"],
							"query": [
								{
									"key": "jobNumber",
									"value": "{{jobNumber}}"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						}
					}
				}
			]
		},
